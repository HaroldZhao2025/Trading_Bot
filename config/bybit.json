{
  "max_open_trades": 2,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "dry_run": true,
  "dry_run_wallet": 1000,
  "timeframe": "5m",
  "tradable_balance_ratio": 0.95,
  "cancel_open_orders_on_exit": true,
  "process_throttle_secs": 5,

  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "check_depth_of_market": { "enabled": false, "bids_to_ask_delta": 1 }
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "stoploss": "market",
    "stoploss_on_exchange": false
  },
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "unit": "minutes"
  },

  "exchange": {
    "name": "bybit",
    "key": "${EXCHANGE_KEY}",
    "secret": "${EXCHANGE_SECRET}",
    "ccxt_config": { "enableRateLimit": true },
    "ccxt_async_config": { "enableRateLimit": true },
    "pair_whitelist": ["BTC/USDT", "ETH/USDT"],
    "pair_blacklist": []
  },

  "pairlists": [
    { "method": "StaticPairList" }
  ],

  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "username": "admin",
    "password": "admin",
    "jwt_secret_key": "somethingRandomSomethingRandom123",
    "verbosity": "error",
    "enable_openapi": true
  },

  "bot_name": "otomic-algorithm",
  "initial_state": "running"
}